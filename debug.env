# Debug environment variables for local development
# MinIO credentials
S3_USER=PLACEHOLDER_S3_USER
S3_PASSWORD=PLACEHOLDER_S3_PASSWORD

# Postgres credentials
POSTGRES_USER=PLACEHOLDER_POSTGRES_USER
POSTGRES_PASSWORD=PLACEHOLDER_POSTGRES_PASSWORD

# Optional: control how far back FTP downloader fetches (if used by services built from project)
FTP_DOWNLOAD_FROM_YEAR=2024

# Optional: GitHub secrets placeholders (if you later enable builds that need them)
GITHUB_USERNAME=PLACEHOLDER_GITHUB_USERNAME
GITHUB_TOKEN=PLACEHOLDER_GITHUB_TOKEN
